# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# --- Database ---
DATABASE_URL=postgresql+psycopg://poker:poker@db:5432/poker

# --- Google OAuth (from Google Cloud Console > APIs & Services > Credentials) ---
# Create an "OAuth client ID" of type "Web application" and add this Authorized
# redirect URI:  ${APP_BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LLM backends (AI coach + LLM opponent bots) ---
# The client in shared_services/llm.py routes by model-name prefix:
#   OpenAI  -> default (e.g. gpt-5-mini, gpt-4.1-mini)  needs OPENAI_API_KEY
#   MiniMax -> model name starts with "minimax"          needs MINIMAX_API_KEY
#   Ollama  -> model name starts with qwen/llama/mistral/ollama (local, no key)
OPENAI_API_KEY=
MINIMAX_API_KEY=
# Base URL for a local Ollama server. In Docker this is set to http://ollama:11434.
OLLAMA_BASE_URL=http://localhost:11434

# --- Logging ---
# Directory where prompt audit logs (prompts.jsonl) are written.
# Default: logs/ (relative to the working directory, i.e. /app/logs in Docker).
# In production point this at a persistent volume, e.g. /var/log/pokertrainer
LOG_DIR=logs

# Minimum log level emitted to stderr. One of: DEBUG INFO WARNING ERROR CRITICAL
LOG_LEVEL=INFO

# Set to 1 to emit JSON on stderr in addition to the log file.
# Recommended for production so your log aggregator (Datadog, CloudWatch, Loki…)
# can ingest structured records without a parser plugin.
LOG_JSON=0

# --- Session / app ---
# Base URL the app is served from (used to build the OAuth callback). Use the
# exact origin you open in the browser and registered with Google.
APP_BASE_URL=http://localhost:8000
# Stable random secret for signing the session cookie (e.g. `openssl rand -hex 32`).
SESSION_SECRET=change-me-to-a-long-random-string
